# ============================================================================
# CouchMail — environment variables reference
# Copy to .env for local Docker testing, or set as Fly.io secrets.
#
# BUILD-TIME  — NEXT_PUBLIC_* are baked into the client bundle at build time.
#               Pass with --build-arg in Docker / flyctl deploy.
# RUNTIME     — All others are injected at container start.
#               Never bake secrets into an image layer.
# ============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# BUILD-TIME (also needed at runtime for server-side clients)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# RUNTIME only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── App URL ───────────────────────────────────────────────────────────────────
# BUILD-TIME — used in Stripe success/cancel redirect URLs
NEXT_PUBLIC_SITE_URL=https://workspaceflow.fly.dev

# RUNTIME — set to "" in Docker (nginx routes /api/* on the same origin)
# Set to http://localhost:8000 for local non-Docker development
NEXT_PUBLIC_BACKEND_URL=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# BUILD-TIME (client ID is safe to expose)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# RUNTIME only
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── Stripe ────────────────────────────────────────────────────────────────────
# BUILD-TIME (publishable keys are safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_PLUS_PRICE_ID=price_...

# RUNTIME only
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── OpenAI ────────────────────────────────────────────────────────────────────
# RUNTIME only — used by FastAPI backend
OPENAI_API_KEY=sk-proj-...

# ── CORS ──────────────────────────────────────────────────────────────────────
# In Docker/Fly.io nginx handles routing so same-origin applies.
# Set to your public URL for defence-in-depth.
ALLOWED_ORIGINS=https://workspaceflow.fly.dev

# ── Email delivery (SMTP via Gmail App Password) ──────────────────────────────
# Enable 2-FA on your Gmail account, then generate an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_EMAIL=your-app@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
ADMIN_EMAIL=admin@example.com

# ── Telegram delivery (python-telegram-bot) ───────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → follow prompts
# 2. Copy the HTTP API token here
# 3. Register the webhook after deploy:
#    curl "https://api.telegram.org/bot{TOKEN}/setWebhook?url=https://workspaceflow.fly.dev/api/telegram/webhook"
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIjKlMnOpQrStUvWxYz
